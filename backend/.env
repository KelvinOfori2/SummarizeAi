# Application
APP_NAME=SummarizeAI
APP_ENV=development
DEBUG=false
SECRET_KEY=summarizeai-super-secret-key-local-dev-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — update this with your PostgreSQL password
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/summarize_ai

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://localhost:8000

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Admin account (auto-created on first run)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@summarizeai.com
ADMIN_PASSWORD=Admin@123456

# Email (optional — for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@summarizeai.com
